PORT=5000
LOCAL_DATA_MODE=mock
# DATABASE_URL=postgres://user:password@localhost:5432/now_padel
SESSION_SECRET=change-me-in-local-development
BOOTSTRAP_AUTH_USERS_JSON=[{"email":"admin@nowpadel.local","name":"Admin","password":"admin123"}]

# Modes:
# - mock: local tests, no real WhatsApp messages
# - evolution: automatic sends through Evolution API
# - manual: fallback to generated WhatsApp Web links
WHATSAPP_SEND_MODE=mock
WHATSAPP_DEFAULT_COUNTRY_CODE=351
WHATSAPP_SENDER_NUMBER=351914742002

# Enable these only after the Evolution API instance is running and paired.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=now-padel-test
EVOLUTION_SEND_DELAY_MS=1200
